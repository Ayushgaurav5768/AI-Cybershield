APP_NAME=AI CyberShield
ENVIRONMENT=development
DEBUG=false

DATABASE_URL=sqlite:///./cybershield.db
CORS_ORIGINS=http://127.0.0.1:8000,https://ai-cybershield-phi.vercel.app

OPENAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-2.0-flash
WARM_ASSISTANT_ON_STARTUP=false
ENABLE_RAG_SCAN_EXPLANATION=false

MAX_SCAN_REQUESTS_PER_MINUTE=120
MAX_GENERAL_REQUESTS_PER_MINUTE=300

MODEL_PATH=ml/model.pkl
MODEL_META_PATH=ml/model_meta.json
